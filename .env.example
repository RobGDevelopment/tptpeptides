# Firebase Client SDK (public — restrict via Firestore rules + App Check)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: set to "true" to enable Analytics in local dev (requires valid API key + measurement ID)
# NEXT_PUBLIC_FIREBASE_ANALYTICS_DEV=false

# Firebase Admin SDK (server-only — never expose to client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (server-only except publishable key if needed later)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (server-only — transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@tptpeptides.com

# App URL for Stripe redirect URLs and SEO
NEXT_PUBLIC_APP_URL=https://tptpeptides.com

# Firebase App Check (production only — reCAPTCHA Enterprise)
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=
