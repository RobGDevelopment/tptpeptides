# Firebase Client SDK (public — restrict via Firestore rules + App Check)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: set to "true" to enable Analytics in local dev (requires valid API key + measurement ID)
# NEXT_PUBLIC_FIREBASE_ANALYTICS_DEV=false

# Firebase Admin SDK (server-only — never expose to client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (server-only except publishable key if needed later)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — verify domain at https://resend.com/domains before partner invites
# Sandbox (onboarding@resend.dev) only delivers to the Resend account owner email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=invites@tptpeptides.com

# One-time: enable production module flags + tier price lists in Firestore
# npm run enable:prod-modules

# App URL for Stripe redirect URLs and SEO (use Vercel preview until custom domain is live)
NEXT_PUBLIC_APP_URL=https://medfit-pro.vercel.app

# Partner invite emails + password-reset links (defaults to Vercel preview; never localhost)
INVITE_SITE_URL=https://medfit-pro.vercel.app

# Firebase App Check (production only — reCAPTCHA Enterprise)
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Optional observability (leave blank until Sentry project is created)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional Playwright admin E2E (local/CI only — never commit real passwords)
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Optional smoke test target override
# SMOKE_BASE_URL=https://medfit-pro.vercel.app
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# Middesk — EIN / business verification (Bridge P1)
MIDDESK_API_KEY=
# MIDDESK_API_BASE=https://api-sandbox.middesk.com/v1

# Authorize.net — B2B high-risk card gateway (Sprint C)
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
# AUTHORIZE_NET_API_URL=https://api.authorize.net/xml/v1/request.api
AUTHORIZE_NET_SIGNATURE_KEY=

# NMI — alternate B2B card gateway (Sprint C)
NMI_SECURITY_KEY=
# NMI_API_URL=https://secure.networkmerchants.com/api/transact.php
NMI_WEBHOOK_SIGNING_KEY=

# SeamlessChex — B2C ACH (Sprint C)
SEAMLESSCHEX_API_KEY=
# SEAMLESSCHEX_API_BASE=https://api.seamlesschex.com/v1
SEAMLESSCHEX_MERCHANT_ACCOUNT_ID=
SEAMLESSCHEX_WEBHOOK_SECRET=

# PayRam — B2C self-hosted crypto (Sprint C)
PAYRAM_API_BASE=
PAYRAM_API_KEY=
# PAYRAM_DEFAULT_ASSET=USDC
PAYRAM_SETTLEMENT_WALLET=
PAYRAM_WEBHOOK_SECRET=

# Vercel Domains API — satellite provisioning (Sprint D)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# ShipStation — alternate carrier provider (Bridge P2)
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=
# SHIPSTATION_API_BASE=https://ssapi.shipstation.com
# SHIPSTATION_CARRIER_CODE=stamps_com
# SHIPSTATION_SERVICE_CODE=usps_priority_mail

# EasyPost tracking webhook (Sprint E)
# EASYPOST_WEBHOOK_SECRET=

# Supplier EDI — auto-PO Protocol B (Sprint E)
# SUPPLIER_EDI_TOKEN=

# Resend inbound — lexical quarantine webhook (Sprint B2)
# RESEND_INBOUND_WEBHOOK_SECRET=

# QuickBooks Online — headless accounting sync (Sprint F/G)
QBO_REALM_ID=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=
