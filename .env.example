# Firebase Client SDK (public — restrict via Firestore rules + App Check)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: set to "true" to enable Analytics in local dev (requires valid API key + measurement ID)
# NEXT_PUBLIC_FIREBASE_ANALYTICS_DEV=false

# Firebase Admin SDK (server-only — never expose to client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (server-only except publishable key if needed later)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — verify domain at https://resend.com/domains before partner invites
# Sandbox (onboarding@resend.dev) only delivers to the Resend account owner email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=invites@tptpeptides.com

# App URL for Stripe redirect URLs and SEO (use Vercel preview until custom domain is live)
NEXT_PUBLIC_APP_URL=https://medfit-pro.vercel.app

# Partner invite emails + password-reset links (defaults to Vercel preview; never localhost)
INVITE_SITE_URL=https://medfit-pro.vercel.app

# Firebase App Check (production only — reCAPTCHA Enterprise)
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Optional observability (leave blank until Sentry project is created)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional Playwright admin E2E (local/CI only — never commit real passwords)
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Optional smoke test target override
# SMOKE_BASE_URL=https://medfit-pro.vercel.app
# PLAYWRIGHT_BASE_URL=http://localhost:3000
